# ============================================================
#  AiPhone Docker 部署环境变量
#  使用方式：复制此文件为 .env，填入真实凭证
#  注意：.env 已被 .gitignore 排除，不会上传到 GitHub
# ============================================================

# ── 阿里云 AccessKey（CCC SDK 调用）──
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# ── RocketMQ 5.x（CCC 事件推送）──
# endpoint 和 instance_id 非敏感，填入真实值供参考
# access_key/access_secret 是敏感凭证，请填入 .env（不提交 GitHub）
ROCKETMQ_ENDPOINT=rmq-cn-1gy4vp7te02.cn-beijing.rmq.aliyuncs.com:8080
ROCKETMQ_INSTANCE_ID=rmq-cn-1gy4vp7te02
ROCKETMQ_ACCESS_KEY=your_rocketmq_username
ROCKETMQ_ACCESS_SECRET=your_rocketmq_password

# ── Beebot 智能对话机器人 ──
BEEBOT_AGENT_KEY=your_beebot_agent_key

# ── DashScope 通义千问 LLM ──
DASHSCOPE_API_KEY=sk-your_dashscope_api_key
