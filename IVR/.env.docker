# ==================== Python IVR Docker 环境配置 ====================
# 此文件含非敏感配置，挂载到容器内 /app/.env
# 敏感凭证（阿里云 AK/SK、RocketMQ 密钥、DashScope Key、Beebot Key）
# 通过 docker-compose.yml 的 environment 直接注入容器环境变量
# pydantic-settings 优先读环境变量，再读 .env 文件

# ── 阿里云区域 ──
ALIYUN_REGION_ID=cn-shanghai

# ── CCC 云联络中心 ──
CCC_INSTANCE_ID=demo-1334882287961657
CCC_CALLBACK_TOKEN=

# ── RocketMQ 5.x ──
ROCKETMQ_TOPIC=testTopic

# ── Beebot 智能对话机器人 ──
BEEBOT_INSTANCE_ID=chatbot-cn-i7QInbE3jb

# ── PostgreSQL（Docker 内部服务名）──
PG_HOST=postgres
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=123456
PG_DATABASE=ai_phone

# ── SQLite 智能坐席库（容器内持久化路径）──
ROBOT_DB_PATH=/app/data/robot_agent.db

# ── Redis（Docker 内部服务名）──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── 智能坐席槽位数 ──
ROBOT_SLOT_COUNT=2

# ── Java 后端 API 地址（Docker 内部服务名）──
JAVA_API_BASE_URL=http://java-backend:8080

# ── 知识库 Excel（通过 volume 挂载到 /app/data/）──
KB_EXCEL_PATH=/app/data/副本知识库导出记录-20260629.xlsx

# ── LLM 模型 ──
LLM_MODEL=qwen3.7-max
