# ============================================================
# 市场监督管理局智能语音工单系统 - 环境配置模板
# 复制此文件为 .env 并填写真实参数
# ============================================================

# ── 阿里云 AccessKey ──────────────────────────────────────
# RAM访问控制 > 用户 > 创建 AccessKey
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_REGION_ID=cn-shanghai

# ── CCC 云联络中心 ────────────────────────────────────────
# CCC控制台 > 实例管理 > 实例详情
CCC_INSTANCE_ID=ccc-test
CCC_CALLBACK_TOKEN=your_ccc_callback_token

# CCC 技能组（在 CCC 控制台 > 实例管理 > 技能组 中获取）
# 格式: 技能组名称@实例ID，如 jinengzixun@dadong
CCC_SKILL_GROUP_ID=jinengzixun@dadong

# 智能机器人坐席前缀（用于在 AssignAgent 事件中通过 agentId 识别机器人）
# CCC 中机器人坐席的 agentId 以此前缀开头，如 robot_1@dadong
# 如果未配置，则通过 agentId 是否含 "robot" 判断
CCC_ROBOT_AGENT_PREFIX=robot

# ── RocketMQ 5.x（CCC 事件推送通道）─────────────────────
# 1. 在 RocketMQ 控制台创建 5.x 实例
# 2. 在 CCC 控制台 > 事件订阅 中配置 RocketMQ
# 3. 填入以下信息
# 接入点不带 http:// 前缀，如 rmq-cn-xxx.cn-beijing.rmq.aliyuncs.com:8080
ROCKETMQ_ENDPOINT=rmq-cn-xxx.cn-beijing.rmq.aliyuncs.com:8080
ROCKETMQ_INSTANCE_ID=rmq-cn-xxx
ROCKETMQ_TOPIC=testTopic
ROCKETMQ_GROUP_ID=GID_CCC_TEST_CONSUMER
# RocketMQ 实例用户名密码（在 RocketMQ 控制台 > 实例 > 接入点 页面查看，非阿里云AK/SK）
ROCKETMQ_ACCESS_KEY=your_rocketmq_username
ROCKETMQ_ACCESS_SECRET=your_rocketmq_password

# ── Beebot 智能对话机器人（通义版）────────────────────────
# 智能对话机器人控制台 > 机器人管理 > 实例详情
BEEBOT_INSTANCE_ID=chatbot-cn-dDmF3jcdVf
BEEBOT_AGENT_KEY=your_beebot_agent_key

# ── PostgreSQL 主库（工单系统）──────────────────────────
# 本地或云数据库，存储工单、对话明细、人工坐席信息
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=ivr_system

# ── SQLite 智能坐席库（robot_agent.db）──────────────────
# 本地 SQLite 文件，存储智能坐席状态（与主库隔离）
# 启动时自动创建数据库文件、建表、初始化机器人坐席记录
# 路径可以是相对路径（相对项目根目录）或绝对路径
ROBOT_DB_PATH=robot_agent.db

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── 智能坐席槽位数 ────────────────────────────────────────
# 与 CCC 控制台配置的智能语音交互节点并发数一致
ROBOT_SLOT_COUNT=2

# ── 知识库 Excel ──────────────────────────────────────────
# 格式：分组名 | 问题 | 相似问法 | 答案
# 分组名含"拒绝"的归入拒绝解答列表
KB_EXCEL_PATH=d:\IVR\副本知识库导出记录-20260629.xlsx

# ── LLM 通义千问（DashScope）────────────────────────────
# DashScope 控制台 > API-KEY 管理
DASHSCOPE_API_KEY=your_dashscope_api_key
LLM_MODEL=qwen-plus

# ── OSS 对象存储（测试报告归档，可选）────────────────────
# 留空则降级为本地保存
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
